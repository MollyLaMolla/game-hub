// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// In the User model, we have a unique name + tag combination, so that users can have the same name as long as their tags are different. The tag and the name are decided by the user, the tag can be max 5 characters long and the name can be max 32 characters long. They are both asked when the user signs up, and they can change them later in their profile settings. The tag is generated randomly when the user signs up, but they can change it later if they want to. The tag is also used to generate the user's avatar, so if they change their tag, their avatar will also change. The avatar is generated using the DiceBear Avatars API, which generates a unique avatar based on the user's name and tag combination. The avatar URL is stored in the database so that we don't have to generate it every time we need to display the user's avatar.

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  inGameName    String?   @db.VarChar(32)
  tag           String?   @db.VarChar(5)
  avatarUrl     String?

  accounts      Account[]
  sessions      Session[]
  friendships   Friendship[]   @relation("Friendships")
  friendOf      Friendship[]   @relation("FriendOf")
  sentFriendRequests     FriendRequest[] @relation("SentFriendRequests")
  receivedFriendRequests FriendRequest[] @relation("ReceivedFriendRequests")
  ownedLobbies Lobby[] @relation("LobbyOwner")
  lobbyMemberships LobbyMember[]
  matchParticipations MatchParticipant[]

  createdAt     DateTime  @default(now())

  onboardingCompleted Boolean @default(false)

  @@unique([inGameName, tag])
}

enum GameKey {
  TICTACTOE
}

enum LobbyQueueType {
  PUBLIC
  PRIVATE
}

enum LobbyStatus {
  OPEN
  SEARCHING
  IN_PROGRESS
}

enum MatchStatus {
  ACTIVE
  FINISHED
}

model Lobby {
  id           String         @id @default(cuid())
  ownerId      String
  currentMatchId String?
  gameKey      GameKey
  queueType    LobbyQueueType
  status       LobbyStatus    @default(OPEN)
  inviteCode   String         @unique @db.VarChar(12)
  partySize    Int
  totalPlayers Int
  teamCount    Int
  teamSize     Int
  startedAt    DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  owner   User          @relation("LobbyOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  currentMatch Match?   @relation(fields: [currentMatchId], references: [id], onDelete: SetNull)
  members LobbyMember[]

  @@index([ownerId, status])
  @@index([status, updatedAt])
  @@index([currentMatchId])
}

model LobbyMember {
  id        String   @id @default(cuid())
  lobbyId    String
  userId     String
  slotIndex  Int
  joinedAt   DateTime @default(now())
  lastSeenAt DateTime? @default(now())

  lobby Lobby @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([lobbyId, userId])
  @@unique([lobbyId, slotIndex])
  @@index([userId])
}

model Match {
  id           String         @id @default(cuid())
  gameKey      GameKey
  queueType    LobbyQueueType
  status       MatchStatus    @default(ACTIVE)
  totalPlayers Int
  state        Json
  createdAt    DateTime       @default(now())
  startedAt    DateTime       @default(now())
  finishedAt   DateTime?

  lobbies      Lobby[]
  participants MatchParticipant[]

  @@index([gameKey, queueType, status])
}

model MatchParticipant {
  id        String   @id @default(cuid())
  matchId    String
  userId     String
  seatIndex  Int
  joinedAt   DateTime @default(now())
  lastSeenAt DateTime? @default(now())

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId])
  @@unique([matchId, seatIndex])
  @@index([userId])
}

model Friendship {
  id        String   @id @default(cuid())
  userId    String
  friendId  String
  createdAt DateTime @default(now())

  user   User @relation("Friendships", fields: [userId], references: [id], onDelete: Cascade)
  friend User @relation("FriendOf", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
  @@index([userId])
  @@index([friendId])
}

model FriendRequest {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  createdAt  DateTime @default(now())

  sender   User @relation("SentFriendRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedFriendRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}